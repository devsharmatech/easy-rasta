									"description": "New photo (REQUIRED)",
									"type": "file",
									"src": ""
								},
								{
									"key": "receipt",
									"description": "New receipt (REQUIRED for correction)",
									"type": "file",
									"src": ""
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/api/mobile/earning/fuel/correct",
							"host": ["{{base_url}}"],
							"path": ["api", "mobile", "earning", "fuel", "correct"]
						},
						"description": "Submit a correction for a DISPUTED fuel report.\n\n**Reward**: ₹10 (1000 paise) to corrector\n\n**Effect**: Original scout's reward is FROZEN (debited from wallet)\n\n**Pre-requisite**: Report must have status 'disputed' (verifier said NO)"
					},
					"response": []
