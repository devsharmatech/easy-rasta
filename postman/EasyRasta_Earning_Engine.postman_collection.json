	"item": [
		{
			"name": "1. Chain of Truth — Fuel",
			"item": [
				{
					"name": "1.1 Fuel Scout (FormData)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.report_id) {",
									"    pm.collectionVariables.set('fuel_report_id', jsonData.data.report_id);",
									"    console.log('Saved fuel_report_id:', jsonData.data.report_id);",
									"}",
									"",
									"pm.test('Status is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has reward data', function() {",
									"    pm.expect(jsonData.data).to.have.property('reward_given');",
									"    pm.expect(jsonData.data).to.have.property('report_id');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{rider_token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
