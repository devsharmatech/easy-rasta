{
	"info": {
		"_postman_id": "easy-rasta-earning-engine-v1",
		"name": "Easy Rasta — Earning Engine",
		"description": "Complete test suite for the Easy Rasta Earning Engine.\n\n## Setup\n1. Set `base_url` variable (e.g., http://localhost:3000)\n2. Set `rider_token` — JWT from rider login\n3. Set `admin_token` — JWT from admin login\n4. Set `cron_secret` — your CRON_SECRET env value\n\n## Test Order\n1. Fuel Scout → Fuel Verify → Fuel Correct\n2. Toilet Scout → Toilet Verify → Toilet Correct\n3. Receipt → Odometer → Garage Service\n4. Event Check-in → Event RSVP Reward\n5. Sponsorship → Admin Approve\n6. Referral Activate\n7. Bunk Profile → Bunk Offer\n8. Summary\n9. Cooldown Cron",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "rider_token",
			"value": "YOUR_RIDER_JWT_TOKEN_HERE",
			"type": "string"
		},
		{
			"key": "rider_token_2",
			"value": "SECOND_RIDER_JWT_TOKEN_FOR_VERIFY",
			"type": "string"
		},
		{
			"key": "admin_token",
			"value": "YOUR_ADMIN_JWT_TOKEN_HERE",
			"type": "string"
		},
		{
			"key": "cron_secret",
			"value": "YOUR_CRON_SECRET_HERE",
			"type": "string"
		},
		{
			"key": "fuel_report_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "toilet_report_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "event_id",
			"value": "YOUR_EVENT_UUID_HERE",
			"type": "string"
		},
		{
			"key": "vehicle_id",
			"value": "YOUR_VEHICLE_UUID_HERE",
			"type": "string"
