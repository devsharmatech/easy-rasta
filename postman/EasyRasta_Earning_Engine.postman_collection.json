									"value": "103.00",
									"description": "Corrected petrol price",
									"type": "text"
								},
								{
									"key": "price_diesel",
									"value": "90.00",
									"description": "Corrected diesel price",
									"type": "text"
								},
								{
									"key": "odometer_reading",
									"value": "15250",
									"description": "Current odometer reading",
									"type": "text"
								},
								{
									"key": "latitude",
									"value": "12.9716",
									"type": "text"
								},
								{
									"key": "longitude",
									"value": "77.5946",
									"type": "text"
								},
								{
