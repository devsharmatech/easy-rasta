						"url": {
							"raw": "{{base_url}}/api/mobile/earning/fuel/scout",
							"host": ["{{base_url}}"],
							"path": ["api", "mobile", "earning", "fuel", "scout"]
						},
						"description": "Submit a new fuel bunk report.\n\n**Reward**: ₹10 (1000 paise)\n\n**Required**: photo, at least one price, GPS\n\n**GPS Rule**: Must be within 100m of bunk (if bunk coords provided)\n\n**Auto-saves** `fuel_report_id` for verify/correct tests."
					},
					"response": []
				},
				{
					"name": "1.2 Fuel Verify (JSON)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('Status is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has reward data', function() {",
									"    pm.expect(jsonData.data).to.have.property('reward_given');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{rider_token_2}}",
								"description": "Use a DIFFERENT rider token (can't verify own report)",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"report_id\": \"{{fuel_report_id}}\",\n    \"latitude\": 12.9716,\n    \"longitude\": 77.5946,\n    \"verification_result\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/mobile/earning/fuel/verify",
							"host": ["{{base_url}}"],
							"path": ["api", "mobile", "earning", "fuel", "verify"]
						},
						"description": "Verify a fuel report (confirm or dispute).\n\n**Reward**: ₹5 (500 paise)\n\n**Rules**:\n- Must use different rider than scout\n- Must be within 100m of bunk\n- Report must be 24h+ old\n- First verifier wins (atomic)\n\n**verification_result**:\n- `true` = confirmed correct → status 'verified'\n- `false` = disputed → status 'disputed' (opens for correction)\n\n⚠️ **24h cooldown**: You'll get `cooldown` reason if report is less than 24h old."
					},
					"response": []
				},
				{
					"name": "1.3 Fuel Correct (FormData)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test('Status is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('Response has correction data', function() {",
									"    pm.expect(jsonData.data).to.have.property('reward_given');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
